<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Copy Diff Checker</title>
<script src="https://cdn.jsdelivr.net/npm/diff@5.2.0/dist/diff.min.js"></script>
<style>
  *{box-sizing:border-box;margin:0;padding:0}
  :root{
    --font-sans:-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif;
    --font-mono:ui-monospace,SFMono-Regular,Menlo,Monaco,Consolas,monospace;
    --color-text-primary:#1f2937;
    --color-text-secondary:#4b5563;
    --color-text-tertiary:#9ca3af;
    --color-background-primary:#ffffff;
    --color-background-secondary:#f3f4f6;
    --color-border-tertiary:rgba(0,0,0,0.08);
    --color-border-secondary:rgba(0,0,0,0.15);
    --color-border-primary:rgba(0,0,0,0.25);
    --border-radius-md:8px;
    --border-radius-lg:12px;
  }
  body{
    font-family:var(--font-sans);
    color:var(--color-text-primary);
    background:#f8f9fa;
    margin:0;
    padding:2rem 1rem;
  }
  .container{max-width:1100px;margin:0 auto;}
  h1{font-size:1.4rem;font-weight:600;margin-bottom:1.25rem;color:var(--color-text-primary);}
  .textareas{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:12px}
  .ta-wrap{display:flex;flex-direction:column;gap:6px}
  .ta-label{font-size:12px;color:var(--color-text-secondary);display:flex;justify-content:space-between;align-items:center}
  .ta-label span{font-size:11px;color:var(--color-text-tertiary)}
  textarea{
    width:100%;height:200px;padding:10px 12px;
    font-family:var(--font-mono);font-size:13px;line-height:1.6;
    border:0.5px solid var(--color-border-secondary);
    border-radius:var(--border-radius-md);
    background:var(--color-background-primary);
    color:var(--color-text-primary);
    resize:vertical;outline:none;transition:border-color .15s;
  }
  textarea:focus{border-color:var(--color-border-primary);box-shadow:0 0 0 2px rgba(0,0,0,0.06)}
  textarea::placeholder{color:var(--color-text-tertiary)}
  .toolbar{
    display:flex;align-items:center;gap:8px;
    margin-bottom:12px;flex-wrap:wrap;
    background:#fff;border:0.5px solid var(--color-border-tertiary);
    border-radius:var(--border-radius-md);
    padding:8px 12px;
  }
  .seg{display:flex;border:0.5px solid var(--color-border-secondary);border-radius:var(--border-radius-md);overflow:hidden}
  .seg button{
    background:none;border:none;padding:5px 12px;font-size:12px;
    cursor:pointer;color:var(--color-text-secondary);transition:background .1s,color .1s;
    font-family:var(--font-sans);
  }
  .seg button.active{background:var(--color-background-secondary);color:var(--color-text-primary);font-weight:500}
  .seg button:hover:not(.active){background:var(--color-background-secondary)}
  .seg button+button{border-left:0.5px solid var(--color-border-tertiary)}
  .seg-label{font-size:11px;color:var(--color-text-tertiary);margin-right:2px}
  .spacer{flex:1}
  .btn{
    border:0.5px solid var(--color-border-secondary);
    border-radius:var(--border-radius-md);
    padding:5px 14px;font-size:12px;cursor:pointer;
    background:var(--color-background-primary);
    color:var(--color-text-primary);
    transition:background .1s;
    font-family:var(--font-sans);
  }
  .btn:hover{background:var(--color-background-secondary)}
  .btn.primary{
    background:var(--color-text-primary);
    color:var(--color-background-primary);
    border-color:transparent;
  }
  .btn.primary:hover{opacity:.85}
  .btn:disabled{opacity:.4;cursor:not-allowed}
  .stats{display:none;gap:8px;margin-bottom:12px}
  .stat{
    flex:1;padding:8px 12px;
    background:#fff;border:0.5px solid var(--color-border-tertiary);
    border-radius:var(--border-radius-md);font-size:12px;
  }
  .stat .label{color:var(--color-text-secondary);margin-bottom:3px}
  .stat .val{font-weight:500;font-size:14px;display:flex;gap:6px;align-items:baseline}
  .stat .delta{font-size:12px;font-weight:500}
  .add-d{color:#1a7f37}.rem-d{color:#cf222e}.neu-d{color:var(--color-text-secondary)}
  .output-wrap{
    border:0.5px solid var(--color-border-tertiary);
    border-radius:var(--border-radius-lg);
    background:var(--color-background-primary);
    min-height:80px;overflow:hidden;
  }
  .output-header{
    display:flex;align-items:center;justify-content:space-between;
    padding:8px 14px;border-bottom:0.5px solid var(--color-border-tertiary);
    font-size:12px;color:var(--color-text-secondary);
  }
  .legend{display:flex;gap:12px;align-items:center}
  .leg-item{display:flex;align-items:center;gap:4px;font-size:11px}
  .leg-dot{width:10px;height:10px;border-radius:2px}
  .leg-add{background:#e6ffec}
  .leg-rem{background:#ffebe9}
  #output{padding:14px;font-family:var(--font-mono);font-size:13px;line-height:1.8;white-space:pre-wrap;word-break:break-word}
  #output.placeholder{font-family:var(--font-sans);color:var(--color-text-tertiary);font-size:13px;padding:24px 14px;text-align:center}
  .ins{background:#e6ffec;color:#1a7f37;border-radius:2px;padding:0 1px}
  .del{background:#ffebe9;color:#cf222e;text-decoration:line-through;border-radius:2px;padding:0 1px}
  .split-table{width:100%;border-collapse:collapse;table-layout:fixed}
  .split-table td{
    width:50%;padding:8px 14px;vertical-align:top;
    font-family:var(--font-mono);font-size:13px;line-height:1.8;
    white-space:pre-wrap;word-break:break-word;
    border-bottom:0.5px solid var(--color-border-tertiary);
  }
  .split-table td:first-child{border-right:0.5px solid var(--color-border-tertiary)}
  .split-table tr:last-child td{border-bottom:none}
  .split-table .bg-add{background:#f0fff4}
  .split-table .bg-rem{background:#fff5f5}
  .split-table .bg-change{background:#fffbea}
  .split-table .empty-cell{background:var(--color-background-secondary)}
  .copy-btn{
    border:none;background:none;cursor:pointer;
    font-size:11px;color:var(--color-text-secondary);
    padding:2px 6px;border-radius:3px;transition:background .1s;
    font-family:var(--font-sans);
  }
  .copy-btn:hover{background:var(--color-background-secondary)}
  .no-diff{
    display:flex;align-items:center;gap:8px;
    padding:20px 14px;color:#1a7f37;
    font-family:var(--font-sans);font-size:13px;
  }
  .no-diff-icon{
    width:18px;height:18px;background:#e6ffec;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-size:10px;flex-shrink:0;
  }
  .kbd{
    display:inline-block;font-size:10px;padding:1px 5px;
    background:var(--color-background-secondary);
    border:0.5px solid var(--color-border-secondary);
    border-radius:3px;font-family:var(--font-mono);
    color:var(--color-text-secondary);
  }
</style>
</head>
<body>
<div class="container">
  <h1>Copy Diff Checker</h1>

  <div class="textareas">
    <div class="ta-wrap">
      <div class="ta-label">Original <span id="orig-count">0 words</span></div>
      <textarea id="orig" placeholder="Paste original text here…" oninput="onInput()" spellcheck="false"></textarea>
    </div>
    <div class="ta-wrap">
      <div class="ta-label">Revised <span id="rev-count">0 words</span></div>
      <textarea id="rev" placeholder="Paste revised text here…" oninput="onInput()" spellcheck="false"></textarea>
    </div>
  </div>

  <div class="toolbar">
    <span class="seg-label">Granularity</span>
    <div class="seg" id="granularity">
      <button class="active" onclick="setGranularity('word',this)">Word</button>
      <button onclick="setGranularity('char',this)">Character</button>
      <button onclick="setGranularity('line',this)">Line</button>
    </div>
    <span class="seg-label" style="margin-left:4px">View</span>
    <div class="seg" id="view">
      <button class="active" onclick="setView('inline',this)">Inline</button>
      <button onclick="setView('split',this)">Split</button>
    </div>
    <div class="spacer"></div>
    <span style="font-size:11px;color:var(--color-text-tertiary)"><span class="kbd">⌘</span> <span class="kbd">↵</span> to compare</span>
    <button class="btn" onclick="clearAll()">Clear</button>
    <button class="btn" id="copyBtn" onclick="copyResult()" disabled>Copy result</button>
    <button class="btn primary" onclick="compare()">Compare</button>
  </div>

  <div class="stats" id="stats">
    <div class="stat"><div class="label">Words</div><div class="val" id="s-words">—</div></div>
    <div class="stat"><div class="label">Characters</div><div class="val" id="s-chars">—</div></div>
    <div class="stat"><div class="label">Added</div><div class="val"><span id="s-add" class="add-d">—</span></div></div>
    <div class="stat"><div class="label">Removed</div><div class="val"><span id="s-rem" class="rem-d">—</span></div></div>
  </div>

  <div class="output-wrap">
    <div class="output-header">
      <div class="legend">
        <div class="leg-item"><div class="leg-dot leg-add"></div>Added</div>
        <div class="leg-item"><div class="leg-dot leg-rem"></div>Removed</div>
      </div>
      <button class="copy-btn" id="copyResultBtn" onclick="copyResult()" style="display:none">Copy</button>
    </div>
    <div id="output" class="placeholder">Paste text into both fields and click Compare.</div>
  </div>
</div>

<script>
  let granularity = 'word', viewMode = 'inline', lastDiff = null;

  function wc(t){ return t.trim() ? t.trim().split(/\s+/).length : 0; }

  function onInput(){
    document.getElementById('orig-count').textContent = wc(document.getElementById('orig').value) + ' words';
    document.getElementById('rev-count').textContent  = wc(document.getElementById('rev').value)  + ' words';
  }

  function setGranularity(g, btn){
    granularity = g;
    document.querySelectorAll('#granularity button').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    if(lastDiff !== null) compare();
  }

  function setView(v, btn){
    viewMode = v;
    document.querySelectorAll('#view button').forEach(b => b.classList.remove('active'));
    btn.classList.add('active');
    if(lastDiff !== null) compare();
  }

  function clearAll(){
    ['orig','rev'].forEach(id => document.getElementById(id).value = '');
    document.getElementById('orig-count').textContent = '0 words';
    document.getElementById('rev-count').textContent  = '0 words';
    const out = document.getElementById('output');
    out.className = 'placeholder';
    out.textContent = 'Paste text into both fields and click Compare.';
    document.getElementById('stats').style.display = 'none';
    document.getElementById('copyBtn').disabled = true;
    document.getElementById('copyResultBtn').style.display = 'none';
    lastDiff = null;
  }

  function escHtml(t){
    return t.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
  }

  // Returns [leftHtml, rightHtml] with word-level highlights for a changed line pair
  function innerDiffHtml(oldLine, newLine){
    const parts = Diff.diffWordsWithSpace(oldLine, newLine);
    let left = '', right = '';
    parts.forEach(p => {
      const t = escHtml(p.value);
      if(p.removed)      left  += `<span class="del">${t}</span>`;
      else if(p.added)   right += `<span class="ins">${t}</span>`;
      else { left += t; right += t; }
    });
    return [left, right];
  }

  function compare(){
    const orig = document.getElementById('orig').value;
    const rev  = document.getElementById('rev').value;
    if(!orig && !rev) return;

    const parts = Diff.diffWordsWithSpace(orig, rev);
    lastDiff = parts;

    const out = document.getElementById('output');
    out.className = '';

    if(viewMode === 'inline'){
      renderInline(parts, out);
    } else {
      renderSplit(orig, rev, out);
    }

    updateStats(orig, rev, parts);
    document.getElementById('copyBtn').disabled = false;
    document.getElementById('copyResultBtn').style.display = 'block';
  }

  function renderInline(parts, container){
    let hasDiff = false, html = '';
    parts.forEach(p => {
      const t = escHtml(p.value);
      if(p.added)        { html += `<span class="ins">${t}</span>`; hasDiff = true; }
      else if(p.removed) { html += `<span class="del">${t}</span>`; hasDiff = true; }
      else               { html += `<span>${t}</span>`; }
    });
    container.innerHTML = hasDiff
      ? html
      : `<div class="no-diff"><div class="no-diff-icon">✓</div>No differences found — the texts are identical.</div>`;
  }

  function renderSplit(orig, rev, container){
    const origLines = orig.split('\n');
    const revLines  = rev.split('\n');
    const lineDiff  = Diff.diffArrays(origLines, revLines);

    // Collect rows, pairing removed+added lines so we can inner-diff them
    const rows = [];
    let i = 0;
    while(i < lineDiff.length){
      const part = lineDiff[i];
      if(!part.removed && !part.added){
        part.value.forEach(line => rows.push({ type:'equal', line }));
        i++;
      } else {
        let removed = [], added = [];
        while(i < lineDiff.length && (lineDiff[i].removed || lineDiff[i].added)){
          if(lineDiff[i].removed) removed = removed.concat(lineDiff[i].value);
          else                    added   = added.concat(lineDiff[i].value);
          i++;
        }
        const len = Math.max(removed.length, added.length);
        for(let j = 0; j < len; j++){
          const r = removed[j], a = added[j];
          if(r !== undefined && a !== undefined) rows.push({ type:'change',  removed:r, added:a });
          else if(r !== undefined)               rows.push({ type:'removed', line:r });
          else                                   rows.push({ type:'added',   line:a });
        }
      }
    }

    let hasDiff = false;
    let html = '<table class="split-table"><tbody>';
    rows.forEach(row => {
      if(row.type === 'equal'){
        const e = escHtml(row.line) || '&nbsp;';
        html += `<tr><td>${e}</td><td>${e}</td></tr>`;
      } else if(row.type === 'change'){
        hasDiff = true;
        const [lh, rh] = innerDiffHtml(row.removed, row.added);
        html += `<tr><td class="bg-change">${lh||'&nbsp;'}</td><td class="bg-change">${rh||'&nbsp;'}</td></tr>`;
      } else if(row.type === 'removed'){
        hasDiff = true;
        html += `<tr><td class="bg-rem"><span class="del">${escHtml(row.line)||'&nbsp;'}</span></td><td class="empty-cell"></td></tr>`;
      } else {
        hasDiff = true;
        html += `<tr><td class="empty-cell"></td><td class="bg-add"><span class="ins">${escHtml(row.line)||'&nbsp;'}</span></td></tr>`;
      }
    });
    html += '</tbody></table>';

    container.innerHTML = hasDiff
      ? html
      : `<div class="no-diff"><div class="no-diff-icon">✓</div>No differences found — the texts are identical.</div>`;
  }

  function updateStats(orig, rev, parts){
    document.getElementById('stats').style.display = 'flex';
    const ow = wc(orig), rw = wc(rev), wd = rw - ow;
    const oc = orig.length, rc = rev.length, cd = rc - oc;
    let addedChars = 0, removedChars = 0;
    parts.forEach(p => {
      if(p.added)        addedChars   += p.value.length;
      else if(p.removed) removedChars += p.value.length;
    });
    function fmtD(n){
      if(n > 0) return `<span class="delta add-d">+${n}</span>`;
      if(n < 0) return `<span class="delta rem-d">${n}</span>`;
      return `<span class="delta neu-d">±0</span>`;
    }
    document.getElementById('s-words').innerHTML = `${ow} → ${rw} ${fmtD(wd)}`;
    document.getElementById('s-chars').innerHTML = `${oc} → ${rc} ${fmtD(cd)}`;
    document.getElementById('s-add').textContent = `+${addedChars} chars`;
    document.getElementById('s-rem').textContent = `−${removedChars} chars`;
  }

  function copyResult(){
    const out = document.getElementById('output');
    navigator.clipboard.writeText(out.innerText || out.textContent).then(() => {
      const btn = document.getElementById('copyBtn');
      const orig = btn.textContent;
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = orig, 1500);
    });
  }

  document.addEventListener('keydown', e => {
    if((e.ctrlKey || e.metaKey) && e.key === 'Enter') compare();
  });
</script>
</body>
</html>
